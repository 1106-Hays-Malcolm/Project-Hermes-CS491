{
  "vision_config_path": "vision_config.json",
  "text_config_path": "text_config.json",
  "transcript_config_path": "transcript_config.json",
  "rag_config_path": "rag_config.json",
  "vision": {
    "roi_left": 500,
    "roi_top": 500,
    "roi_width": 50,
    "roi_height": 50,
    "save_screenshot": true,
    "screenshot_path": "screenshot.png",
    "prompt_template": "Read the coordinates exactly as shown in the image. The text is expected to look like {expected_format} where # are replaced with the numbers/coordinates you see. Return only the text you see. Do not return JSON. Do not explain anything. Ensuare the values you see are accurate to the what you see in the image. If you do NOT see any coordinate values, simply return 'NO VALUES FOUND'. ",
    "expected_format": "X:# / Y:#",
    "capture_interval_seconds": 3.0
  },
  "text": {
    "prompt_template": "{rag_context}\nCurrent map: {selected_map}\nUser query: {user_text}"
  },
  "transcript": {
    "directory": "hermes_transcripts",
    "filename_prefix": "transcript",
    "encoding": "utf-8"
  },
  "rag": null,
  "metrics": {
    "enabled": false,
    "output_path": "hermes_metrics.jsonl"
  },
  "pumps": [
    {
      "backend": "llamacpp",
      "name": "gemma_pump",
      "model_name": "unsloth/gemma-4-E2B-it-GGUF",
      "device": "cuda",
      "capabilities": [
        "text",
        "vision"
      ],
      "max_new_tokens": 128,
      "do_sample": true,
      "text_uses_processor": true,
      "use_turboquant": true,
      "turboquant_bits": 4,
      "load_in_4bit": true,
      "load_in_8bit": false,
      "model_path": null,
      "gguf_filename": "*Q4_0.gguf",
      "clip_model_path": null,
      "n_gpu_layers": -1,
      "n_ctx": 0
    }
  ],
  "pipeline_subscriptions": {
    "text": "gemma_pump",
    "vision": "gemma_pump"
  }
}