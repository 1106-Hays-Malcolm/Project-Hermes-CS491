{
  "vision_config_path": "vision_config.json",
  "text_config_path": "text_config.json",
  "transcript_config_path": "transcript_config.json",
  "rag_config_path": "rag_config.json",
  "vision": {
    "roi_left": 0,
    "roi_top": 0,
    "roi_width": 1920,
    "roi_height": 1080,
    "save_screenshot": true,
    "screenshot_path": "screenshot.png",
    "prompt_template": "Describe the image in detail.",
    "expected_format": "X:123 Y:456",
    "capture_interval_seconds": 8.0
  },
  "text": {
    "prompt_template": "{rag_context}\nCurrent map: {selected_map}\nUser query: {user_text}"
  },
  "transcript": {
    "directory": "hermes_transcripts",
    "filename_prefix": "transcript",
    "encoding": "utf-8"
  },
  "rag": null,
  "metrics": {
    "enabled": false,
    "output_path": "hermes_metrics.jsonl"
  },
  "pumps": [
    {
      "backend": "llamacpp",
      "name": "gemma_pump",
      "model_name": "unsloth/gemma-4-E2B-it-GGUF",
      "device": "cuda",
      "capabilities": [
        "text",
        "vision"
      ],
      "max_new_tokens": 512,
      "do_sample": true,
      "text_uses_processor": true,
      "use_turboquant": true,
      "turboquant_bits": 4,
      "load_in_4bit": true,
      "load_in_8bit": false,
      "model_path": null,
      "gguf_filename": "*Q4_K_M.gguf",
      "clip_gguf_filename": "mmproj-BF16.gguf",
      "clip_model_path": null,
      "n_gpu_layers": -1,
      "n_ctx": 0
    }
  ],
  "pipeline_subscriptions": {
    "text": "gemma_pump",
    "vision": "gemma_pump"
  }
}